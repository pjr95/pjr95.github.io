---
interface FocusItem {
  title: string;
  detail: string;
}

const { items } = Astro.props as { items: FocusItem[] };
---

<section class="shell pb-16">
  <div class="panel rounded-[32px] p-6 md:p-8">
    <div class="max-w-3xl">
      <p class="text-sm uppercase tracking-[0.28em] text-sky-200/70">Current focus</p>
      <h2 class="mt-2 text-2xl font-semibold text-white md:text-3xl">What I’m focused on right now</h2>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {items.map((item) => (
        <article class="rounded-[24px] border border-white/10 bg-white/4 p-5">
          <h3 class="text-lg font-semibold text-white">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-300">{item.detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>

---
interface Item {
  period: string;
  title: string;
  org: string;
  summary: string;
}

const { items } = Astro.props as { items: Item[] };
---

<section class="shell pb-16">
  <div class="mb-6 flex items-end justify-between gap-4">
    <div>
      <p class="text-sm uppercase tracking-[0.28em] text-sky-200/70">Timeline</p>
      <h2 class="mt-2 text-2xl font-semibold text-white md:text-3xl">A readable backbone under the playful UI</h2>
    </div>
  </div>
  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {items.map((item) => (
      <article class="panel rounded-3xl p-5">
        <div class="text-xs uppercase tracking-[0.22em] text-slate-400">{item.period}</div>
        <h3 class="mt-3 text-lg font-semibold text-white">{item.title}</h3>
        <p class="mt-1 text-sm text-sky-200/90">{item.org}</p>
        <p class="mt-4 text-sm leading-6 text-slate-300">{item.summary}</p>
      </article>
    ))}
  </div>
</section>

---
interface Principle {
  title: string;
  summary: string;
}

const { items } = Astro.props as { items: Principle[] };
---

<section class="shell pb-16">
  <div class="mb-8 max-w-3xl">
    <p class="text-sm uppercase tracking-[0.28em] text-sky-200/70">How I work</p>
    <h2 class="mt-2 text-2xl font-semibold text-white md:text-3xl">A few principles behind the work</h2>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    {items.map((item) => (
      <article class="panel rounded-[28px] p-6">
        <h3 class="text-lg font-semibold text-white">{item.title}</h3>
        <p class="mt-3 text-sm leading-6 text-slate-300">{item.summary}</p>
      </article>
    ))}
  </div>
</section>

---
interface Capability {
  title: string;
  kicker: string;
  summary: string;
  bullets: string[];
}

const { items } = Astro.props as { items: Capability[] };
---

<section id="capabilities" class="shell pb-16 md:pb-20">
  <div class="mb-8 max-w-3xl">
    <p class="text-sm uppercase tracking-[0.28em] text-sky-200/70">Capabilities</p>
    <h2 class="mt-2 text-2xl font-semibold text-white md:text-3xl">A clearer view of what I bring</h2>
    <p class="mt-3 text-sm leading-6 text-slate-300 md:text-base">
      Instead of an abstract graph, this is the shape of the work itself: the areas I keep operating in, the strengths that connect them, and the kind of value I tend to create.
    </p>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {items.map((item) => (
      <article class="panel rounded-[28px] p-6">
        <p class="text-xs uppercase tracking-[0.22em] text-slate-400">{item.kicker}</p>
        <h3 class="mt-3 text-xl font-semibold text-white">{item.title}</h3>
        <p class="mt-4 text-sm leading-6 text-slate-300">{item.summary}</p>
        <ul class="mt-5 space-y-2 text-sm text-slate-200">
          {item.bullets.map((bullet) => (
            <li class="flex gap-3">
              <span class="mt-[0.35rem] h-1.5 w-1.5 rounded-full bg-sky-300"></span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>

---
interface Item {
  title: string;
  summary: string;
  detail: string;
}

const { items } = Astro.props as { items: Item[] };
---

<section class="shell pb-16">
  <div class="mb-6 max-w-3xl">
    <p class="text-sm uppercase tracking-[0.28em] text-sky-200/70">What I work on</p>
    <h2 class="mt-2 text-2xl font-semibold text-white md:text-3xl">The problems and patterns that keep pulling me in</h2>
    <p class="mt-3 text-sm leading-6 text-slate-300 md:text-base">
      Not case studies in the confidential sense, but the kinds of work I keep returning to, and the way I tend to think about them.
    </p>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {items.map((item) => (
      <article class="panel rounded-[28px] p-6">
        <h3 class="text-lg font-semibold text-white">{item.title}</h3>
        <p class="mt-3 text-sm font-medium leading-6 text-sky-100/90">{item.summary}</p>
        <p class="mt-4 text-sm leading-6 text-slate-300">{item.detail}</p>
      </article>
    ))}
  </div>
</section>

---
interface Props {
  profile: {
    name: string;
    headline: string;
    location: string;
    tagline: string;
    summary: string;
    links: Record<string, string>;
    stats: { label: string; value: string }[];
  };
}

const { profile } = Astro.props;
---

<section class="shell pt-10 pb-8 md:pt-16 md:pb-12">
  <div class="panel glow rounded-[32px] px-6 py-8 md:px-10 md:py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="mb-3 text-sm uppercase tracking-[0.28em] text-sky-200/70">Pablo Romero</p>
        <h1 class="text-4xl font-semibold tracking-tight md:text-6xl">{profile.name}</h1>
        <p class="mt-3 text-lg text-sky-100/90 md:text-2xl">{profile.headline}</p>
        <p class="mt-2 text-sm text-slate-400">{profile.location}</p>
        <p class="mt-5 text-lg font-medium text-sky-100/95 md:text-xl">{profile.tagline}</p>
        <p class="mt-5 max-w-xl text-base leading-7 text-slate-300 md:text-lg">{profile.summary}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="rounded-full bg-sky-400 px-5 py-2.5 text-sm font-medium text-slate-950 transition hover:bg-sky-300" href="#capabilities">View capabilities</a>
          <a class="rounded-full border border-white/15 px-5 py-2.5 text-sm font-medium text-slate-100 transition hover:border-sky-300/50 hover:bg-white/5" href={profile.links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a class="rounded-full border border-white/15 px-5 py-2.5 text-sm font-medium text-slate-100 transition hover:border-sky-300/50 hover:bg-white/5" href={profile.links.email}>Email</a>
        </div>
      </div>
      <div class="grid gap-3 md:w-[320px]">
        {profile.stats.map((stat) => (
          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
            <div class="text-xs uppercase tracking-[0.22em] text-slate-400">{stat.label}</div>
            <div class="mt-2 text-sm font-medium text-slate-100">{stat.value}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
import Hero from '../components/Hero.astro';
import Timeline from '../components/Timeline.astro';
import Capabilities from '../components/Capabilities.astro';
import Highlights from '../components/Highlights.astro';
import WhatIWorkOn from '../components/WhatIWorkOn.astro';
import profile from '../data/profile.json';
import timeline from '../data/timeline.json';
import highlights from '../data/highlights.json';
import work from '../data/work.json';
import capabilities from '../data/capabilities.json';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pablo Romero | AI, ML, Systems, and Teaching</title>
    <meta
      name="description"
      content="A personal site for Pablo Romero, spanning AI, machine learning, systems, leadership, and teaching."
    />
  </head>
  <body>
    <Hero profile={profile} />
    <Capabilities items={capabilities.items} />
    <WhatIWorkOn items={work.items} />
    <Highlights items={highlights.items} />
    <Timeline items={timeline.items} />
  </body>
</html>

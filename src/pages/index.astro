---
import Hero from '../components/Hero.astro';
import Timeline from '../components/Timeline.astro';
import Pillars from '../components/Pillars.astro';
import Highlights from '../components/Highlights.astro';
import HowIWork from '../components/HowIWork.astro';
import CurrentFocus from '../components/CurrentFocus.astro';
import profile from '../data/profile.json';
import timeline from '../data/timeline.json';
import highlights from '../data/highlights.json';
import pillars from '../data/pillars.json';
import howIWork from '../data/how-i-work.json';
import currentFocus from '../data/current-focus.json';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pablo Romero | AI, ML, Systems, and Teaching</title>
    <meta
      name="description"
      content="A personal site for Pablo Romero, spanning AI, machine learning, systems, leadership, and teaching."
    />
  </head>
  <body>
    <Hero profile={profile} />
    <Pillars items={pillars.items} />
    <Highlights items={highlights.items} />
    <HowIWork items={howIWork.items} />
    <CurrentFocus items={currentFocus.items} />
    <Timeline items={timeline.items} />
  </body>
</html>
